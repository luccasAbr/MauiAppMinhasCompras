<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.Relatorio"
             Title="Relatorio">
    <StackLayout Padding="10">
        <Frame BackgroundColor="{StaticResource Gray100}" Margin="0,0,0,10" Padding="10">
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="Filtrar dia:" VerticalTextAlignment="Center" FontAttributes="Bold" />
                <DatePicker x:Name="dtp_filtro" 
                            Format="dd/MM/yyyy" 
                            DateSelected="dtp_filtro_DateSelected" />
            </HorizontalStackLayout>
        </Frame>

        <ListView x:Name="lst_relatorio">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid ColumnDefinitions="*, Auto" Padding="10">
                            <Label Grid.Column="0" Text="{Binding Descricao}" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding Total, StringFormat='{}{0:C}'}" TextColor="Green" />
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Label x:Name="lbl_soma_dia" 
               HorizontalOptions="End" 
               FontAttributes="Bold" 
               FontSize="18" 
               Margin="0,10,0,0" />
    </StackLayout>
</ContentPage>